{
  "name": "nexus-agent",
  "version": "1.0.0",
  "description": "Nexus Agent — Autonomous multi-agent AI system with CLI, Web UI, multi-provider LLM support, and local model capability",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nexus": "./dist/cli.js"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "cli": "tsx src/cli.ts",
    "cli:chat": "tsx src/cli.ts chat",
    "cli:serve": "tsx src/cli.ts serve",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --external:z-ai-web-dev-sdk --allow-overwrite",
    "build:binary": "node scripts/build-binary.js",
    "build:all": "npm run build:cli && npm run build:binary"
  },
  "files": [
    "dist/",
    "README.md",
    "install.sh",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "cybersecurity",
    "cli",
    "web-ui",
    "llm",
    "ollama",
    "local-ai",
    "nexus-agent"
  ],
  "license": "MIT",
  "author": "Botan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Botan-linux/nexus-agent.git"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "chalk": "^5.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "ora": "^8.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "z-ai-web-dev-sdk": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
