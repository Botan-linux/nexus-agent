# Nexus Agent — Environment Variables
# Copy this file to .env and fill in your values

# ─── LLM Provider API Keys ─────────────────────────
# Z.ai SDK (built-in, no key needed for default)

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (Local Models) ─────────────────────────
# Ollama runs locally at this URL
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model
OLLAMA_MODEL=llama3

# ─── Web UI Server ─────────────────────────────────
# Port for 'nexus serve' command
NEXUS_PORT=3000

# ─── GitHub ────────────────────────────────────────
# For development/publishing (not required for users)
GITHUB_TOKEN=
